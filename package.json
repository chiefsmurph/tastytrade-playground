{
  "name": "tastytrade-playground",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test src/**/*.test.ts",
    "build": "esbuild src/index.ts --bundle --platform=node --format=esm --packages=external --sourcemap --outfile=build/index.js",
    "start:tsx": "tsx src/index.ts",
    "start:build": "node build/index.js",
    "start": "npm run start:tsx",
    "dev": "tsx watch src/index.ts"
  },
  "dependencies": {
    "@tastytrade/api": "^7.0.2",
    "axios": "^1.6.0",
    "dotenv": "^16.0.0",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "esbuild": "^0.25.6",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
