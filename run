#!/usr/bin/env node
import { sendIpcCommand } from "./ipc-client.js";

const [, , command, ...args] = process.argv;

async function usage(exitCode = 0) {
  console.log("Usage: node run <namespace:function> [args...]");
  console.log("Example: node run core:getBidAskForSymbol AAPL");
  console.log("\nOptions:");
  console.log("  -h, --help   Show this help message");

  try {
    const commands = await sendIpcCommand("core:listCommands", []);
    if (Array.isArray(commands) && commands.length > 0) {
      console.log("\nAvailable IPC commands:");
      for (const item of commands) {
        console.log(`- ${item}`);
      }
    }
  } catch {
    console.log("\nAvailable IPC commands:");
    console.log("  Start the server first with: npm run start:tsx");
    console.log("  Then run: node run core:listCommands");
  }

  process.exit(exitCode);
}

if (!command || command === "--help" || command === "-h") {
  await usage(command ? 0 : 1);
}

try {
  const result = await sendIpcCommand(command, args);

  if (typeof result === "string") {
    console.log(result);
  } else {
    console.log(JSON.stringify(result, null, 2));
  }
} catch (error) {
  const message = error instanceof Error ? error.message : String(error);
  console.error(message);

  if (message.includes("Could not connect to IPC server")) {
    console.error("Start the server first with: npm run start:tsx");
    process.exit(4);
  }

  process.exit(2);
}