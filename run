#!/usr/bin/env node
import { sendIpcCommand } from "./ipc-client.js";

const [, , command, ...args] = process.argv;

function usage() {
  console.error("Usage: node run <namespace:function> [args...]");
  console.error("Example: node run core:getBidAskForSymbol AAPL");
  process.exit(1);
}

if (!command) {
  usage();
}

try {
  const result = await sendIpcCommand(command, args);

  if (typeof result === "string") {
    console.log(result);
  } else {
    console.log(JSON.stringify(result, null, 2));
  }
} catch (error) {
  const message = error instanceof Error ? error.message : String(error);
  console.error(message);

  if (message.includes("Could not connect to IPC server")) {
    console.error("Start the server first with: npm run start:tsx");
    process.exit(4);
  }

  process.exit(2);
}